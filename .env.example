NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173,https://your-frontend.vercel.app,https://www.yourdomain.com

# Primary fallback target (also used when SCRAPE_TARGETS is omitted)
TARGET_URL=https://matkaking.boston/

# Comma-separated list of websites to scrape
SCRAPE_TARGETS=https://matkaking.boston/
SCRAPE_INTERVAL_MS=6000
SCRAPE_TIMEOUT_MS=15000
SCRAPE_RETRIES=1
SCRAPE_RETRY_DELAY_MS=500

# In-memory state/history settings
MAX_HISTORY_LENGTH=50
STALE_AFTER_MS=1800000

# API protection
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=240
RATE_LIMIT_STRICT_MAX=60
BODY_LIMIT=10kb
TRUST_PROXY=true
CSRF_TOKEN=replace-with-secure-random-token

# Logging + streaming
LOG_LEVEL=info
SSE_HEARTBEAT_ENABLED=true
SSE_HEARTBEAT_MS=15000

# Matka admin/live module (side-by-side with scraper)
MONGODB_URI=
JWT_SECRET=
JWT_EXPIRES_IN=1d
ADMIN_USERNAME=
# Generate with: node -e "import bcrypt from 'bcryptjs'; bcrypt.hash('your-password', 12).then(console.log)"
ADMIN_PASSWORD_HASH=
MATKA_TIMEZONE=Asia/Kolkata
MATKA_REVEAL_LOADING_MS=15000
MATKA_PRE_REVEAL_LOADING_MS=15000
MATKA_PRIORITY_LEAD_MS=360000
MARKET_CONTENT_SOURCE=mongo
MARKET_CONTENT_CACHE_TTL_MS=300000

# On-demand market scraping (lazy scrape from matkaking.boston)
# Enable/disable on-demand scraping (true/false, default: true)
MARKET_SCRAPE_ENABLED=true
# HTTP request timeout for scraping in milliseconds (1000–60000, default: 15000)
MARKET_SCRAPE_TIMEOUT_MS=15000
# Cache TTL for scraped content in milliseconds (10000–86400000, default: 300000)
MARKET_SCRAPE_CACHE_TTL_MS=300000
# Comma-separated list of market slugs excluded from scraping (served from MongoDB only)
MARKET_SCRAPE_EXCLUDED_SLUGS=
# Base URL for the scraping target
MARKET_SCRAPE_BASE_URL=https://matkaking.boston

# Frontend (Vercel) optional override for admin/live API direct calls
# Example: https://boss-ehz0.onrender.com
VITE_MATKA_API_BASE_URL=
VITE_CONTENT_API_BASE_URL=
RENDER_BACKEND_URL=
VITE_CSRF_TOKEN=
VITE_API_TIMEOUT_MS=30000
VITE_MARKET_LIVE_REFRESH_MS=6000
VITE_MARKET_CONTENT_RETRY_MS=6000

# Contact form SMTP (sends form submissions to your inbox)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=support@matkaking.cc
SMTP_PASS=
SMTP_FROM=support@matkaking.cc
CONTACT_EMAIL_TO=support@matkaking.cc
